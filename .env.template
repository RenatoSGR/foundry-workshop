# ============================================
# Azure AI Foundry - Workshop Configuration
# ============================================
# Copia este ficheiro para .env e preenche com os teus valores
# cp .env.template .env

# --- Azure AI Foundry Project ---
AZURE_AI_FOUNDRY_ENDPOINT=https://<nome-do-teu-projeto>.services.ai.azure.com
AZURE_AI_FOUNDRY_KEY=<a-tua-key-aqui>
AZURE_AI_FOUNDRY_PROJECT=<nome-do-projeto>
AZURE_SUBSCRIPTION_ID=<o-teu-subscription-id>
AZURE_RESOURCE_GROUP=<o-teu-resource-group>

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://<nome-do-recurso>.openai.azure.com/
AZURE_OPENAI_KEY=<a-tua-key-aqui>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# --- Azure OpenAI Embeddings ---
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# --- Azure AI Search (para Lab 4 - RAG) ---
AZURE_SEARCH_ENDPOINT=https://<nome-do-search>.search.windows.net
AZURE_SEARCH_KEY=<a-tua-admin-key-aqui>
AZURE_SEARCH_INDEX=workshop-index

# --- Azure API Management (para Lab 6 - APIM) ---
APIM_ENDPOINT=https://<nome-do-apim>.azure-api.net
APIM_SUBSCRIPTION_KEY=<a-tua-subscription-key-aqui>
